  "authors": [
    "Leafuke"
  ],
  "contact": {
    "homepage": "https://folderrewind.top/",
    "sources": "https://github.com/Leafuke/DeathRewind"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.leafuke.deathrewind.DeathRewind"
    ],
    "client": [
      "com.leafuke.deathrewind.DeathRewindClient"
    ]
  },
  "mixins": [
    "deathrewind.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": ">=1.21 <1.21.11",
    "java": ">=21",
    "fabric-api": "*"
